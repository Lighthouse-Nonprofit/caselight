.row
  .col-xs-12.col-sm-6.col-sm-offset-3.col-md-4.col-md-offset-4
    .ibox.normal-space
      .ibox-title.text-center
        = image_tag('brand/caselight-logo.png', alt: 'CaseLight', style: 'max-width: 260px; width: 100%; height: auto;')
      .ibox-content
        = simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
          = f.error_notification
          .form-inputs
            = f.input :email, required: false, autofocus: true, label: t('.email')
            = f.input :password, required: false, label: t('.password')
            -# Two-factor code — only required for accounts that have enabled MFA; ignored otherwise.
            = f.input :otp_attempt, required: false, label: t('.otp_attempt', default: 'Two-factor code'), hint: t('.otp_hint', default: 'Only if you have enabled two-factor authentication'), input_html: { autocomplete: 'one-time-code', inputmode: 'numeric' }
            = f.input :remember_me, as: :boolean, input_html: { class: 'i-checks' }, label: t('.remember_me') if devise_mapping.rememberable?
            = f.submit t('.login'), class: 'btn btn-block btn-outline btn-primary'
            .text-center
              %hr
              = render "devise/shared/links"
