.row
  .col-xs-12.col-sm-6.col-sm-offset-3.col-md-4.col-md-offset-4
    .ibox.normal-space
      .ibox-title.text-center
        = image_tag('brand/caselight-logo.png', alt: 'CaseLight', style: 'max-width: 260px; width: 100%; height: auto;')
      .ibox-content
        = simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
          = f.error_notification
          .form-inputs
            = f.input :email, required: false, autofocus: true, label: t('.email')
            = f.input :password, required: false, label: t('.password')
            -# Accounts with MFA enabled are prompted for their code on the next screen (two-step login).
            = f.input :remember_me, as: :boolean, input_html: { class: 'i-checks' }, label: t('.remember_me') if devise_mapping.rememberable?
            = f.submit t('.login'), class: 'btn btn-block btn-outline btn-primary'
            -# Passwordless passkey sign-in (WebAuthn) — ADDITIVE third option. Hidden if the browser
            -# lacks WebAuthn support / is not a secure context (the inline JS reveals it).
            #passkey-login-area{ style: 'display:none' }
              %hr
              %button#passkey-login.btn.btn-block.btn-default{ type: 'button' }
                %i.fa.fa-key
                = ' Sign in with a passkey'
              %p#passkey-login-status.text-danger.text-center.m-t{ style: 'display:none' }
            %noscript
              %p.text-muted.text-center.m-t Passkey sign-in requires JavaScript.
            .text-center
              %hr
              = render "devise/shared/links"

  :javascript
    (function () {
      if (!window.PublicKeyCredential) { return; }
      var area = document.getElementById('passkey-login-area');
      if (area) { area.style.display = 'block'; }

      function b64uToBuf(s) {
        s = s.replace(/-/g, '+').replace(/_/g, '/');
        while (s.length % 4) { s += '='; }
        var bin = atob(s), buf = new Uint8Array(bin.length);
        for (var i = 0; i < bin.length; i++) { buf[i] = bin.charCodeAt(i); }
        return buf.buffer;
      }
      function bufToB64u(buf) {
        var bytes = new Uint8Array(buf), s = '';
        for (var i = 0; i < bytes.length; i++) { s += String.fromCharCode(bytes[i]); }
        return btoa(s).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
      }
      function csrf() {
        var m = document.querySelector('meta[name=csrf-token]');
        return m ? m.content : '';
      }
      function postJSON(url, body) {
        return fetch(url, {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf() },
          body: JSON.stringify(body || {})
        });
      }
      function setStatus(msg) {
        var el = document.getElementById('passkey-login-status');
        if (!el) { return; }
        el.textContent = msg || '';
        el.style.display = msg ? 'block' : 'none';
      }

      var btn = document.getElementById('passkey-login');
      if (!btn) { return; }
      btn.addEventListener('click', function () {
        setStatus('');
        var emailField = document.querySelector('input[name="user[email]"]');
        var email = emailField ? emailField.value : '';
        postJSON('#{passkey_login_options_path}', { email: email }).then(function (r) {
          return r.json();
        }).then(function (options) {
          options.challenge = b64uToBuf(options.challenge);
          (options.allowCredentials || []).forEach(function (c) { c.id = b64uToBuf(c.id); });
          return navigator.credentials.get({ publicKey: options });
        }).then(function (cred) {
          var resp = cred.response;
          var payload = {
            credential: {
              id: cred.id,
              rawId: bufToB64u(cred.rawId),
              type: cred.type,
              response: {
                clientDataJSON: bufToB64u(resp.clientDataJSON),
                authenticatorData: bufToB64u(resp.authenticatorData),
                signature: bufToB64u(resp.signature),
                userHandle: resp.userHandle ? bufToB64u(resp.userHandle) : null
              }
            }
          };
          return postJSON('#{passkey_login_callback_path}', payload);
        }).then(function (r) {
          return r.json().then(function (j) { return { ok: r.ok, body: j }; });
        }).then(function (res) {
          if (res.ok && res.body.redirect) { window.location = res.body.redirect; }
          else { setStatus(res.body.error || 'Passkey sign-in failed.'); }
        }).catch(function (e) {
          setStatus((e && e.message) || 'Passkey sign-in was cancelled.');
        });
      });
    })();
