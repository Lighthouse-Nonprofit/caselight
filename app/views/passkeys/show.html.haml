.row
  .col-xs-12.col-sm-8.col-sm-offset-2.col-md-6.col-md-offset-3
    .ibox.normal-space
      .ibox-title
        %h3 Passkeys
      .ibox-content
        %p Sign in with a passkey — a fingerprint, face, screen-lock PIN, or a security key (YubiKey). A passkey is phishing-resistant and is itself two factors, so it replaces both your password and your authenticator code at sign-in.
        #passkey-unsupported.alert.alert-warning{ style: 'display:none' }
          This browser does not support passkeys, or the page is not served over a secure context (HTTPS, or http://localhost / 127.0.0.1). Passkeys are unavailable here.

        - if @credentials.any?
          %table.table.table-striped
            %thead
              %tr
                %th Name
                %th Added
                %th Last used
                %th
            %tbody
              - @credentials.each do |cred|
                %tr
                  %td= cred.nickname
                  %td= cred.created_at.to_date.to_s
                  %td= cred.last_used_at ? cred.last_used_at.to_date.to_s : 'Never'
                  %td
                    = button_to 'Remove', passkey_path(cred), method: :delete, class: 'btn btn-xs btn-danger', data: { confirm: 'Remove this passkey?' }
        - else
          %p.text-muted You have no passkeys yet.

        %hr
        #passkey-register-area{ data: { options_url: passkey_registration_options_path, passkeys_url: passkeys_path } }
          .form-group
            = label_tag :passkey_nickname, 'Name this device'
            = text_field_tag :passkey_nickname, nil, class: 'form-control', placeholder: 'e.g. My laptop, YubiKey', maxlength: 60
          %button#passkey-register.btn.btn-primary{ type: 'button' } Register this device
          %span#passkey-register-status.text-danger.m-l
