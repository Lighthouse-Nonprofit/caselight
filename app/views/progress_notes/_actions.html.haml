- if can? :manage, ProgressNote
  = link_to edit_client_progress_note_path(object.client, object), class: "btn btn-outline btn-success btn-xs btn-edit #{ability_to_update(ProgressNote)}", 'aria-label': t('shared.actions.edit', default: 'Edit') do
    = fa_icon('pencil', 'aria-hidden': true)
  = link_to [object.client, object], method: 'delete', data: { confirm: t('.are_you_sure') }, class: "btn btn-outline btn-danger btn-xs btn-delete #{ability_to_delete(ProgressNote)}", 'aria-label': t('shared.actions.delete', default: 'Delete') do
    = fa_icon('trash', 'aria-hidden': true)
