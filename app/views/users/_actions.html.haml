- if can? :manage, User
  - if current_user.admin?
    = link_to edit_user_path(object), class: 'btn btn-outline btn-success btn-xs', 'aria-label': t('shared.actions.edit', default: 'Edit') do
      = fa_icon('pencil', 'aria-hidden': true)
  - else
    %a.btn.btn-outline.btn-success.btn-xs.disabled{'aria-label': t('shared.actions.edit', default: 'Edit'), 'aria-disabled': 'true'}
      = fa_icon('pencil', 'aria-hidden': true)
  = link_to user_disable_path(object), class: 'btn btn-outline btn-primary btn-xs', 'aria-label': (object.disable ? t('shared.actions.unlock', default: 'Enable user') : t('shared.actions.lock', default: 'Disable user')) do
    = fa_icon(object.disable ? 'lock' : 'unlock', 'aria-hidden': true)
  = remove_link(object, { user_client: object.clients_count, user_case: object.cases_count,
                          user_ask: object.tasks_count, user_changelog: object.changelogs_count,
                          user_progress_note: object.progress_notes.count })
