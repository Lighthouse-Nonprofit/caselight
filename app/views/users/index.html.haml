.row
  .col-xs-12
    .pull-left
      %button.btn.btn-primary.btn-filter{"aria-expanded" => 'false', "aria-label" => t('shared.actions.filter', default: 'Toggle search filters'), "data-target" => '#user-search-form', "data-toggle" => 'collapse', type: 'button'}
        %i.fa.fa-filter{"aria-hidden" => "true"}
    .pull-right
      - if can? :manage, :all
        = link_to "#{I18n.t('users.index.add_new_user')}", new_user_path, class: 'btn btn-primary'
      = link_to "#{I18n.t('users.index.export_xls')}", current_url(format: 'xls'), class: 'btn btn-info btn-export'
.row.ibox-space
  .col-xs-12
    .ibox.float-e-margins#user-search-form.collapse
      .ibox-content
        = datagrid_form_for @user_grid, url: users_url, html: { class: 'grid-form' }
.row
  .col-xs-12
    .ibox.float-e-margins
      .ibox-title
        %h5= @results
        %span.label.label-info= t('.results')
        .ibox-tools
          %a.collapse-link{"aria-label" => t('shared.actions.collapse', default: 'Collapse panel')}
            %i.fa.fa-chevron-up{"aria-hidden" => "true"}
          %a.fullscreen-link{"aria-label" => t('shared.actions.fullscreen', default: 'Toggle fullscreen')}
            %i.fa.fa-expand{"aria-hidden" => "true"}
      .ibox-content
        .users-table
          = datagrid_table @user_grid, html: { class: 'table table-bordered table-striped table-hover users'}
      .ibox-footer.text-center
        = paginate @user_grid.assets
